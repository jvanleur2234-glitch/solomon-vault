{
  "name": "jackconnect-setup",
  "version": "1.0",
  "description": "Set up JackConnect for a new real estate client — install services and connect integrations",
  "author": "Solomon OS",
  "created": "2026-04-20",
  "params": {
    "client_name": "Acme Realty",
    "client_email": "client@acme.com",
    "domain": "acme.realty"
  },
  "steps": [
    {
      "id": 1,
      "action": "navigate",
      "target": "https://jackconnect.solomon.os/setup",
      "verify": { "type": "url_contains", "value": "/setup" }
    },
    {
      "id": 2,
      "action": "click",
      "target": "#start-wizard",
      "verify": { "type": "text_visible", "value": "New Client Setup" }
    },
    {
      "id": 3,
      "action": "type",
      "target": "#client-name",
      "value": "{{client_name}}",
      "verify": { "type": "text_visible", "value": "{{client_name}}" }
    },
    {
      "id": 4,
      "action": "type",
      "target": "#client-email",
      "value": "{{client_email}}",
      "verify": { "type": "text_visible", "value": "{{client_email}}" }
    },
    {
      "id": 5,
      "action": "click",
      "target": "#continue-btn",
      "verify": { "type": "text_visible", "value": "Connect Services" }
    },
    {
      "id": 6,
      "action": "click",
      "target": "#toggle-ollama",
      "verify": { "type": "text_visible", "value": "Ollama Connected" }
    },
    {
      "id": 7,
      "action": "click",
      "target": "#toggle-groq",
      "verify": { "type": "text_visible", "value": "Groq Connected" }
    },
    {
      "id": 8,
      "action": "click",
      "target": "#continue-btn",
      "verify": { "type": "text_visible", "value": "Assign Workers" }
    },
    {
      "id": 9,
      "action": "click",
      "target": "#worker-russell-tuna",
      "verify": { "type": "element_visible", "value": "#worker-selected" }
    },
    {
      "id": 10,
      "action": "click",
      "target": "#worker-hermes",
      "verify": { "type": "element_visible", "value": "#worker-selected" }
    },
    {
      "id": 11,
      "action": "click",
      "target": "#deploy-btn",
      "verify": { "type": "text_visible", "value": "Deployed" }
    },
    {
      "id": 12,
      "action": "wait",
      "seconds": 5,
      "verify": { "type": "text_visible", "value": "Client Ready" }
    }
  ]
}